# Скопировать в .env и заполнить своими значениями

# PostgreSQL (берёшь из Supabase → Settings → Database)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# JWT — придумай любую длинную случайную строку
JWT_SECRET=my_super_secret_key_change_this_in_production_min_32_chars

# Порт сервера
PORT=3001

# URL фронтенда (для CORS)
FRONTEND_URL=http://localhost:5500

# Supabase Storage (для фото) — берёшь из Supabase → API
SUPABASE_URL=https://[PROJECT].supabase.co
SUPABASE_SERVICE_KEY=eyJ...
